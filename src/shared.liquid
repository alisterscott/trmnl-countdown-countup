{% if testing_date and testing_date != '' %}
    {%- assign todays_date = testing_date -%}
{% else %}
    {%- assign todays_date = "now" -%}
{% endif %}

{%- assign today_timestamp = todays_date | date: "%s" | plus: trmnl.user.utc_offset -%}
{%- assign today_date = today_timestamp | date: "%Y-%m-%d" -%}
{%- assign size = trmnl.plugin_settings.custom_fields_values.size | default: "standard" | downcase -%}
{%- assign resolved_target_date = trmnl.plugin_settings.custom_fields_values.target_date | default: target_date | default: today_date -%}

{%- assign today_midnight_ts = today_date | date: "%s" | plus: 0 -%}
{%- assign target_midnight_ts = resolved_target_date | date: "%s" | plus: 0 -%}
{%- assign day_diff = target_midnight_ts | minus: today_midnight_ts | divided_by: 86400 -%}

{%- assign day_count = day_diff -%}
{%- assign relation = "until" -%}
{%- if day_diff < 0 -%}
  {%- assign relation = "since" -%}
  {%- assign day_count = day_diff | times: -1 -%}
{%- endif -%}

{%- assign day_unit = "days" -%}
{%- if day_count == 1 -%}
  {%- assign day_unit = "day" -%}
{%- endif -%}

{%- assign target_day = resolved_target_date | date: "%d" | plus: 0 -%}
{%- assign target_month = resolved_target_date | date: "%B" -%}
{%- assign target_year = resolved_target_date | date: "%Y" -%}

{%- assign relation_text = day_unit | append: " " | append: relation -%}


<style>
  /* Tile styling - flip clock aesthetic */
  .fdp-tile {
    border: var(--fdp-tile-border, 4px solid #ccc);
    font-weight: 800;
    overflow: hidden;
    position: relative;
  }

  /* Seam effect (like flip clock seam) */
  .fdp-tile::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: var(--fdp-seam, #555);
    z-index: 10;
  }

  .fdp-tile::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: calc(50% + 2px);
    height: 1px;
    background: var(--fdp-seam-shadow, #222);
    z-index: 9;
  }

  /* Text styling */
  .fdp-number, .fdp-text {
    font-family: 'Inter', 'system-ui', 'Arial', sans-serif;
    font-size: clamp(2rem, 18vw, 14rem);
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .fdp-text--dayofweek {
    font-size: clamp(2rem, 15vw, 14rem);
  }

  .fdp-text--md {
    font-size: clamp(1.5rem, 13vw, 9rem);
  }

  .fdp-text--sm {
    font-size: clamp(1rem, 9vw, 6rem);
  }

  .fdp-text--smm {
    font-size: clamp(1rem, 8vw, 6rem);
  }

  .fdp-text--xs {
    font-size: clamp(0.75rem, 6vw, 4.5rem);
  }

  .fdp-count {
    font-size: clamp(2.25rem, 28vw, 16rem);
    line-height: 0.9;
  }

  .fdp-heading {
    font-size: clamp(1.15rem, 7vw, 4rem);
    letter-spacing: 0.02em;
    text-transform: lowercase;
  }

  .fdp-relation {
    font-size: clamp(1.25rem, 8vw, 4.5rem);
    line-height: 1.1;
    text-align: center;
    text-transform: lowercase;
  }

  .fdp-target {
    font-size: clamp(1.2rem, 8vw, 4.75rem);
    line-height: 1;
  }

  /* Equal-height rows for stacked grid layouts */
  .fdp-equal-rows {
    grid-template-rows: 1fr 1fr;
    grid-auto-rows: 1fr;
  }
</style>
