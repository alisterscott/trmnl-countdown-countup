{% if testing_date and testing_date != '' %}
    {%- assign todays_date = testing_date -%}
{% else %}
    {%- assign todays_date = "now" -%}
{% endif %}

{%- assign today_timestamp = todays_date | date: "%s" | plus: trmnl.user.utc_offset -%}
{%- assign today_date = today_timestamp | date: "%Y-%m-%d" -%}
{%- assign size = trmnl.plugin_settings.custom_fields_values.size | default: "standard" | downcase -%}
{%- assign resolved_target_date = trmnl.plugin_settings.custom_fields_values.target_date | default: target_date | default: today_date -%}

{%- assign today_midnight_ts = today_date | date: "%s" | plus: 0 -%}
{%- assign target_midnight_ts = resolved_target_date | date: "%s" | plus: 0 -%}
{%- assign day_diff = target_midnight_ts | minus: today_midnight_ts | divided_by: 86400 -%}

{%- assign today_day_num = today_date | date: "%d" | plus: 0 -%}
{%- assign today_month_num = today_date | date: "%m" | plus: 0 -%}
{%- assign today_year_num = today_date | date: "%Y" | plus: 0 -%}

{%- assign target_day_num = resolved_target_date | date: "%d" | plus: 0 -%}
{%- assign target_month_num = resolved_target_date | date: "%m" | plus: 0 -%}
{%- assign target_year_num = resolved_target_date | date: "%Y" | plus: 0 -%}

{%- assign day_count = day_diff -%}
{%- assign relation = "until" -%}
{%- if day_diff < 0 -%}
  {%- assign relation = "since" -%}
  {%- assign day_count = day_diff | times: -1 -%}
{%- endif -%}

{%- assign year_diff_abs = target_year_num | minus: today_year_num -%}
{%- if year_diff_abs < 0 -%}
  {%- assign year_diff_abs = year_diff_abs | times: -1 -%}
{%- endif -%}

{%- assign month_diff = target_year_num | minus: today_year_num | times: 12 -%}
{%- assign month_diff = month_diff | plus: target_month_num | minus: today_month_num -%}
{%- assign month_diff_abs = month_diff -%}
{%- if month_diff_abs < 0 -%}
  {%- assign month_diff_abs = month_diff_abs | times: -1 -%}
{%- endif -%}

{%- assign unit_base = "day" -%}

{%- if target_month_num == today_month_num and target_day_num == today_day_num and year_diff_abs > 0 -%}
  {%- assign day_count = year_diff_abs -%}
  {%- assign unit_base = "year" -%}
{%- elsif target_day_num == today_day_num and month_diff_abs > 0 -%}
  {%- assign day_count = month_diff_abs -%}
  {%- assign unit_base = "month" -%}
{%- else -%}
  {%- assign day_diff_mod_7 = day_count | modulo: 7 -%}
  {%- if day_count > 0 and day_diff_mod_7 == 0 -%}
  {%- assign week_count = day_count | divided_by: 7 -%}
  {%- if week_count != 52 -%}
    {%- assign day_count = week_count -%}
    {%- assign unit_base = "week" -%}
  {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- assign day_unit = unit_base | append: "s" -%}
{%- if day_count == 1 -%}
  {%- assign day_unit = unit_base -%}
{%- endif -%}

{%- assign target_day = resolved_target_date | date: "%d" | plus: 0 -%}
{%- assign target_month = resolved_target_date | date: "%B" -%}
{%- assign target_year = resolved_target_date | date: "%Y" -%}

{%- assign custom_text = trmnl.plugin_settings.custom_fields_values.custom_text | default: "" -%}
{%- assign use_custom_text = false -%}
{%- if custom_text != "" and custom_text != nil -%}
  {%- assign use_custom_text = true -%}
{%- endif -%}

{%- assign relation_text = day_unit | append: " " | append: relation -%}
{%- assign heading_text = "it is" -%}
{%- if day_diff < 0 -%}
  {%- assign heading_text = "it has been" -%}
{%- endif -%}


<style>
  #fdp-root {
    font-family: Inter, system-ui, Arial, sans-serif;
  }

  /* Tile seam effect for flip clock aesthetic */
  .fdp-tile {
    overflow: hidden;
    position: relative;
  }

  .fdp-tile::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: rgba(255, 255, 255, 0.1);
    z-index: 10;
  }

  .fdp-tile::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: calc(50% + 2px);
    height: 1px;
    background: rgba(0, 0, 0, 0.3);
    z-index: 9;
  }

  /* Responsive typography */
  .fdp-full-heading { font-size: clamp(1rem, 6.2vw, 3.6rem); line-height: 1; }
  .fdp-full-count { font-size: clamp(2rem, 22vw, 12rem); line-height: 0.9; }
  .fdp-full-relation { font-size: clamp(1rem, 6.6vw, 3.8rem); line-height: 1.05; white-space: normal; }
  .fdp-full-target { font-size: clamp(0.95rem, 6vw, 3.4rem); line-height: 1; }

  .fdp-hh-heading { font-size: clamp(0.85rem, 5.2vw, 2.6rem); line-height: 1.05; white-space: normal; }
  .fdp-hh-count { font-size: clamp(1.6rem, 16vw, 6.4rem); line-height: 0.9; }
  .fdp-hh-relation { font-size: clamp(0.9rem, 5.5vw, 2.8rem); line-height: 1.05; white-space: normal; }
  .fdp-hh-target { font-size: clamp(0.8rem, 5vw, 2.2rem); line-height: 1; }

  .fdp-hv-heading { font-size: clamp(0.85rem, 6.2vw, 2.4rem); line-height: 1.05; white-space: normal; }
  .fdp-hv-count { font-size: clamp(1.7rem, 18vw, 6.8rem); line-height: 0.9; }
  .fdp-hv-relation { font-size: clamp(0.85rem, 6vw, 2.4rem); line-height: 1.05; white-space: normal; }
  .fdp-hv-target { font-size: clamp(0.8rem, 5.5vw, 2.1rem); line-height: 1; }

  .fdp-q-heading { font-size: clamp(0.7rem, 5.6vw, 2.2rem); line-height: 1; }
  .fdp-q-count { font-size: clamp(1.4rem, 15vw, 5rem); line-height: 0.9; }
  .fdp-q-relation { font-size: clamp(0.7rem, 5.2vw, 2rem); line-height: 1.05; white-space: normal; }
  .fdp-q-target { font-size: clamp(0.65rem, 4.6vw, 1.8rem); line-height: 1; }

  @media (min-width: 900px) {
    .fdp-full-heading { font-size: clamp(1.3rem, 7vw, 4.8rem); }
    .fdp-full-count { font-size: clamp(2.8rem, 24vw, 15rem); }
    .fdp-full-relation { font-size: clamp(1.4rem, 7.5vw, 5rem); }
    .fdp-full-target { font-size: clamp(1.25rem, 6.8vw, 4.2rem); }

    .fdp-hh-heading { font-size: clamp(1rem, 5.8vw, 3.2rem); }
    .fdp-hh-count { font-size: clamp(2rem, 18vw, 8rem); }
    .fdp-hh-relation { font-size: clamp(1.05rem, 6vw, 3.3rem); }
    .fdp-hh-target { font-size: clamp(0.95rem, 5.5vw, 2.8rem); }

    .fdp-hv-heading { font-size: clamp(1rem, 6.8vw, 3rem); }
    .fdp-hv-count { font-size: clamp(2.2rem, 20vw, 8.5rem); }
    .fdp-hv-relation { font-size: clamp(1rem, 6.5vw, 3rem); }
    .fdp-hv-target { font-size: clamp(0.95rem, 6vw, 2.7rem); }

    .fdp-q-heading { font-size: clamp(0.9rem, 6vw, 2.8rem); }
    .fdp-q-count { font-size: clamp(1.9rem, 17vw, 6.5rem); }
    .fdp-q-relation { font-size: clamp(0.9rem, 5.8vw, 2.5rem); }
    .fdp-q-target { font-size: clamp(0.85rem, 5.2vw, 2.3rem); }
  }
</style>
