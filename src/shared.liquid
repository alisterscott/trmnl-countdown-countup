{% if testing_date and testing_date != '' %}
    {%- assign todays_date = testing_date -%}
{% else %}
    {%- assign todays_date = "now" -%}
{% endif %}

{%- assign today_timestamp = todays_date | date: "%s" | plus: trmnl.user.utc_offset -%}
{%- assign today_date = today_timestamp | date: "%Y-%m-%d" -%}
{%- assign size = trmnl.plugin_settings.custom_fields_values.size | default: "standard" | downcase -%}
{%- assign resolved_target_date = trmnl.plugin_settings.custom_fields_values.target_date | default: target_date | default: today_date -%}

{%- assign today_midnight_ts = today_date | date: "%s" | plus: 0 -%}
{%- assign target_midnight_ts = resolved_target_date | date: "%s" | plus: 0 -%}
{%- assign day_diff = target_midnight_ts | minus: today_midnight_ts | divided_by: 86400 -%}

{%- assign today_day_num = today_date | date: "%d" | plus: 0 -%}
{%- assign today_month_num = today_date | date: "%m" | plus: 0 -%}
{%- assign today_year_num = today_date | date: "%Y" | plus: 0 -%}

{%- assign target_day_num = resolved_target_date | date: "%d" | plus: 0 -%}
{%- assign target_month_num = resolved_target_date | date: "%m" | plus: 0 -%}
{%- assign target_year_num = resolved_target_date | date: "%Y" | plus: 0 -%}

{%- assign day_count = day_diff -%}
{%- assign relation = "until" -%}
{%- if day_diff < 0 -%}
  {%- assign relation = "since" -%}
  {%- assign day_count = day_diff | times: -1 -%}
{%- endif -%}

{%- assign year_diff_abs = target_year_num | minus: today_year_num -%}
{%- if year_diff_abs < 0 -%}
  {%- assign year_diff_abs = year_diff_abs | times: -1 -%}
{%- endif -%}

{%- assign month_diff = target_year_num | minus: today_year_num | times: 12 -%}
{%- assign month_diff = month_diff | plus: target_month_num | minus: today_month_num -%}
{%- assign month_diff_abs = month_diff -%}
{%- if month_diff_abs < 0 -%}
  {%- assign month_diff_abs = month_diff_abs | times: -1 -%}
{%- endif -%}

{%- assign unit_base = "day" -%}

{%- if target_month_num == today_month_num and target_day_num == today_day_num and year_diff_abs > 0 -%}
  {%- assign day_count = year_diff_abs -%}
  {%- assign unit_base = "year" -%}
{%- elsif target_day_num == today_day_num and month_diff_abs > 0 -%}
  {%- assign day_count = month_diff_abs -%}
  {%- assign unit_base = "month" -%}
{%- else -%}
  {%- assign day_diff_mod_7 = day_count | modulo: 7 -%}
  {%- if day_count > 0 and day_diff_mod_7 == 0 -%}
  {%- assign week_count = day_count | divided_by: 7 -%}
  {%- if week_count != 52 -%}
    {%- assign day_count = week_count -%}
    {%- assign unit_base = "week" -%}
  {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- assign day_unit = unit_base | append: "s" -%}
{%- if day_count == 1 -%}
  {%- assign day_unit = unit_base -%}
{%- endif -%}

{%- assign target_day = resolved_target_date | date: "%d" | plus: 0 -%}
{%- assign target_month = resolved_target_date | date: "%B" -%}
{%- assign target_year = resolved_target_date | date: "%Y" -%}

{%- assign custom_text = trmnl.plugin_settings.custom_fields_values.custom_text | default: "" -%}
{%- assign use_custom_text = false -%}
{%- if custom_text != "" and custom_text != nil -%}
  {%- assign use_custom_text = true -%}
{%- endif -%}

{%- assign relation_text = day_unit | append: " " | append: relation -%}
{%- assign heading_text = "it is" -%}
{%- if day_diff < 0 -%}
  {%- assign heading_text = "it has been" -%}
{%- endif -%}


<style>
  /* Tile styling - flip clock aesthetic */
  .fdp-tile {
    border: var(--fdp-tile-border, 4px solid #ccc);
    font-weight: 800;
    overflow: hidden;
    position: relative;
  }

  /* Seam effect (like flip clock seam) */
  .fdp-tile::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: var(--fdp-seam, #555);
    z-index: 10;
  }

  .fdp-tile::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: calc(50% + 2px);
    height: 1px;
    background: var(--fdp-seam-shadow, #222);
    z-index: 9;
  }

  /* Responsive typography */
  .fdp-full-heading { font: 700 clamp(1.15rem, 7.2vw, 4.2rem) / 1 Inter, system-ui, Arial, sans-serif; }
  .fdp-full-count { font: 700 clamp(2.4rem, 25vw, 14rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
  .fdp-full-relation { font: 700 clamp(1.15rem, 7.4vw, 4.3rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-full-target { font: 700 clamp(1.1rem, 6.8vw, 3.9rem) / 1 Inter, system-ui, Arial, sans-serif; }

  .fdp-hh-heading { font: 700 clamp(1rem, 6vw, 3rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-hh-count { font: 700 clamp(1.9rem, 18vw, 7.4rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
  .fdp-hh-relation { font: 700 clamp(1.05rem, 6.2vw, 3.2rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-hh-target { font: 700 clamp(0.95rem, 5.7vw, 2.6rem) / 1 Inter, system-ui, Arial, sans-serif; }

  .fdp-hv-heading { font: 700 clamp(1rem, 6.9vw, 2.9rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-hv-count { font: 700 clamp(2.1rem, 20vw, 8rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
  .fdp-hv-relation { font: 700 clamp(1rem, 6.7vw, 2.9rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-hv-target { font: 700 clamp(0.95rem, 6.1vw, 2.5rem) / 1 Inter, system-ui, Arial, sans-serif; }

  .fdp-q-heading { font: 700 clamp(0.85rem, 6.3vw, 2.6rem) / 1 Inter, system-ui, Arial, sans-serif; }
  .fdp-q-count { font: 700 clamp(1.7rem, 17vw, 6rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
  .fdp-q-relation { font: 700 clamp(0.85rem, 5.9vw, 2.4rem) / 1.05 Inter, system-ui, Arial, sans-serif; white-space: normal; }
  .fdp-q-target { font: 700 clamp(0.8rem, 5.2vw, 2.1rem) / 1 Inter, system-ui, Arial, sans-serif; }

  @media (min-width: 900px) {
    .fdp-full-heading { font: 700 clamp(1.5rem, 8vw, 5.4rem) / 1 Inter, system-ui, Arial, sans-serif; }
    .fdp-full-count { font: 700 clamp(3.2rem, 27vw, 17rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
    .fdp-full-relation { font: 700 clamp(1.65rem, 8.4vw, 5.8rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-full-target { font: 700 clamp(1.45rem, 7.6vw, 4.9rem) / 1 Inter, system-ui, Arial, sans-serif; }

    .fdp-hh-heading { font: 700 clamp(1.2rem, 6.7vw, 3.8rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-hh-count { font: 700 clamp(2.3rem, 20vw, 9.2rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
    .fdp-hh-relation { font: 700 clamp(1.2rem, 6.8vw, 3.8rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-hh-target { font: 700 clamp(1.1rem, 6.3vw, 3.3rem) / 1 Inter, system-ui, Arial, sans-serif; }

    .fdp-hv-heading { font: 700 clamp(1.2rem, 7.5vw, 3.6rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-hv-count { font: 700 clamp(2.6rem, 22vw, 9.8rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
    .fdp-hv-relation { font: 700 clamp(1.15rem, 7.1vw, 3.5rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-hv-target { font: 700 clamp(1.1rem, 6.6vw, 3.2rem) / 1 Inter, system-ui, Arial, sans-serif; }

    .fdp-q-heading { font: 700 clamp(1.05rem, 6.6vw, 3.3rem) / 1 Inter, system-ui, Arial, sans-serif; }
    .fdp-q-count { font: 700 clamp(2.2rem, 19vw, 7.6rem) / 0.9 Inter, system-ui, Arial, sans-serif; }
    .fdp-q-relation { font: 700 clamp(1.05rem, 6.4vw, 3rem) / 1.05 Inter, system-ui, Arial, sans-serif; }
    .fdp-q-target { font: 700 clamp(1rem, 5.8vw, 2.7rem) / 1 Inter, system-ui, Arial, sans-serif; }
  }
</style>
