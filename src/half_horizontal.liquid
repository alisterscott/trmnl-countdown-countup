{% if size == "compact" %}
<div class="layout layout--stretch fdp-root--half-horizontal" id="fdp-root">
  <div class="grid grid--cols-4 gap--[12px]">
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center col--span-4 text--center p--[0.2rem] fdp-text fdp-heading fdp-hh-heading">{{ heading_text }} {{ day_count }} {{ relation_text }}</div>
    {%- if use_custom_text -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center col--span-4 fdp-text fdp-target fdp-hh-target">{{ custom_text }}</div>
    {%- else -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center col--span-4 fdp-text fdp-target fdp-hh-target">{{ target_day }} {{ target_month }} {{ target_year }}</div>
    {%- endif -%}
  </div>
</div>
{% else %}
<div class="layout layout--stretch fdp-root--half-horizontal" id="fdp-root">
  <div class="grid grid--cols-1 gap--[12px]">
    <div class="grid grid--cols-2 gap--[12px]">
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-number fdp-count fdp-hh-count">{{ day_count }}</div>
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center text--center p--[0.2rem] fdp-text fdp-relation fdp-hh-relation">{{ relation_text }}</div>
    </div>
    {%- if use_custom_text -%}
    <div class="grid grid--cols-1 gap--[12px]">
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-target fdp-hh-target">{{ custom_text }}</div>
    </div>
    {%- else -%}
    <div class="grid grid--cols-3 gap--[12px]">
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-target fdp-hh-target fdp-target-day">{{ target_day }}</div>
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-target fdp-hh-target fdp-target-month">{{ target_month }}</div>
      <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-target fdp-hh-target fdp-target-year">{{ target_year }}</div>
    </div>
    {%- endif -%}
  </div>
</div>
{% endif %}

