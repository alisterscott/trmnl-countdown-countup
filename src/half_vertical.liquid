<style>
  #fdp-root.fdp-root--half-vertical .fdp-hv-heading {
    font-size: clamp(0.85rem, 6.2vw, 2.4rem);
    line-height: 1.05;
    white-space: normal;
  }

  #fdp-root.fdp-root--half-vertical .fdp-hv-count {
    font-size: clamp(1.7rem, 18vw, 6.8rem);
    line-height: 0.9;
  }

  #fdp-root.fdp-root--half-vertical .fdp-hv-relation {
    font-size: clamp(0.85rem, 6vw, 2.4rem);
    line-height: 1.05;
    white-space: normal;
  }

  #fdp-root.fdp-root--half-vertical .fdp-hv-target {
    font-size: clamp(0.8rem, 5.5vw, 2.1rem);
    line-height: 1;
  }

  /* TRMNL X emulator/profile: increase typography on wider displays. */
  @media (min-width: 900px) {
    #fdp-root.fdp-root--half-vertical .fdp-hv-heading {
      font-size: clamp(1rem, 6.8vw, 3rem);
    }

    #fdp-root.fdp-root--half-vertical .fdp-hv-count {
      font-size: clamp(2.2rem, 20vw, 8.5rem);
    }

    #fdp-root.fdp-root--half-vertical .fdp-hv-relation {
      font-size: clamp(1rem, 6.5vw, 3rem);
    }

    #fdp-root.fdp-root--half-vertical .fdp-hv-target {
      font-size: clamp(0.95rem, 6vw, 2.7rem);
    }
  }
</style>

{% if size == "compact" %}
<div class="layout layout--stretch fdp-root--half-vertical" id="fdp-root">
  <div class="grid grid--cols-1 gap--[12px] fdp-equal-rows">
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold text--center p--[0.2rem] fdp-text fdp-heading fdp-hv-heading">{{ heading_text }} {{ day_count }}</div>
    {%- if use_custom_text -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold text--center p--[0.2rem] fdp-text fdp-relation fdp-hv-relation">{{ custom_text }}</div>
    {%- else -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold text--center p--[0.2rem] fdp-text fdp-relation fdp-hv-relation">{{ relation_text }}</div>
    {%- endif -%}
  </div>
</div>
{% else %}
<div class="layout layout--stretch fdp-root--half-vertical" id="fdp-root">
  <div class="grid grid--cols-1 gap--[12px]">
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold fdp-number fdp-count fdp-hv-count">{{ day_count }}</div>
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold text--center p--[0.2rem] fdp-text fdp-relation fdp-hv-relation">{{ relation_text }}</div>
    {%- if use_custom_text -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold fdp-text fdp-target fdp-hv-target">{{ custom_text }}</div>
    {%- else -%}
    <div class="fdp-tile bg--black text--white rounded--[12px] border--[4px] border--gray-400 flex flex--row flex--center font--bold fdp-text fdp-target fdp-hv-target fdp-target-combined">{{ target_day }} {{ target_month }} {{ target_year }}</div>
    {%- endif -%}
  </div>
</div>
{% endif %}
