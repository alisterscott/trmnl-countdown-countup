{% if size == "compact" %}
<div class="layout layout--stretch" id="fdp-root">
  <div class="grid grid--cols-1 gap--[12px] fdp-equal-rows">
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-heading">it is {{ day_count }}</div>
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-relation">{{ relation_text }}</div>
  </div>
</div>
{% else %}
<div class="layout layout--stretch" id="fdp-root">
  <div class="grid grid--cols-1 gap--[12px]">
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-number fdp-count">{{ day_count }}</div>
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-relation">{{ relation_text }}</div>
    <div class="fdp-tile bg--black text--white rounded--[12px] flex flex--row flex--center fdp-text fdp-target">{{ target_day }} {{ target_month }} {{ target_year }}</div>
  </div>
</div>
{% endif %}
